# ─────────────────────────────────────────────────────────────
# Supabase — Project Settings → API
# ─────────────────────────────────────────────────────────────
# Public, sent to the browser. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses RLS — NEVER expose to the client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Integrations (stubbed in MVP — fill in when enabling the module)
# ─────────────────────────────────────────────────────────────
# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Clinic SaaS <noreply@example.com>"

# Telegram bot notifications
TELEGRAM_BOT_TOKEN=

# Scheduled reminders (Vercel Cron). The /api/cron/reminders route requires the
# request's `Authorization: Bearer ${CRON_SECRET}` header. Vercel sends this
# automatically for crons when CRON_SECRET is set in the project env.
CRON_SECRET=

# KHQR / Bakong payment integration
KHQR_MERCHANT_ID=
KHQR_API_KEY=
